# =============================================================================
# Template for .env — copy this to ".env" and fill in your values.
#   PowerShell:  Copy-Item .env.example .env
# =============================================================================

# Your timezone — CHANGE THIS. Full list:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC

# User/group the apps run as. Leave as-is.
PUID=1000
PGID=1000

# Where downloads + app settings live (forward slashes). Default is fine for most people.
DATA_ROOT=C:/MediaStack/data
CONFIG_ROOT=C:/MediaStack/config

# Your Plex library folder — CHANGE "YOURNAME" to your Windows account name.
# To find it, run   echo $env:USERPROFILE   in PowerShell, then add /Videos (forward slashes).
VIDEOS_ROOT=C:/Users/YOURNAME/Videos

# -----------------------------------------------------------------------------
# VPN (OPTIONAL) — leave these BLANK for now. Fill them in only when you decide
# to turn the VPN on (see README "Turning on the VPN later"). Reference:
#   VPN_SERVICE_PROVIDER : mullvad | protonvpn | ivpn | pia | ... (gluetun list)
#   VPN_TYPE             : wireguard (recommended) | openvpn
#   WIREGUARD_PRIVATE_KEY: from your provider's WireGuard config
#   WIREGUARD_ADDRESSES  : the address from that config, e.g. 10.2.0.2/32
#   SERVER_CITIES        : optional, e.g. Amsterdam
# -----------------------------------------------------------------------------
VPN_SERVICE_PROVIDER=
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
SERVER_CITIES=
